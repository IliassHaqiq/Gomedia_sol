# Configuration Gomedia IA Specifications API
# ===============================================
# Copiez ce fichier vers .env et modifiez les valeurs
# NE JAMAIS COMMITTER LE FICHIER .env AVEC DES CLÉS RÉELLES !

# ==============================================================================
# API Configuration
# ==============================================================================

# API Key pour authentification (obligatoire pour production)
# À générer avec: openssl rand -hex 32
API_KEY=your_api_key_here_change_this_in_production

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Environnement: development, staging, production
ENVIRONMENT=development

# Port API
PORT=8000

# Taille max upload (en bytes, 10MB par défaut)
MAX_FILE_SIZE=10485760

# ==============================================================================
# Base de Données
# ==============================================================================

# PostgreSQL - Configuration pour pgAdmin
# Host: localhost, Port: 5433, Database: postgres, User: postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres

# Pool configuration
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ==============================================================================
# DeepSeek V4 Pro Configuration (Active)
# ==============================================================================

# API Key DeepSeek (obtenir sur https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# URL de l'API DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Modèle DeepSeek pour la génération de texte
DEEPSEEK_MODEL=deepseek-chat

# Modèle DeepSeek pour les embeddings
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ==============================================================================
# Vector Search Configuration
# ==============================================================================

# Dimension des embeddings (dépend du modèle)
EMBEDDING_DIMENSION=1536

# Seuil de similarité pour la recherche (0-1)
SIMILARITY_THRESHOLD=0.7

# Nombre maximum de résultats de recherche
MAX_SEARCH_RESULTS=10

# ==============================================================================
# LLM Configuration (Ollama - Alternative - Commentée)
# ==============================================================================

# URL Ollama (commentée - utilisez DeepSeek maintenant)
# OLLAMA_URL=http://localhost:11434/api/generate

# Modèle utilisé (commenté - utilisez DeepSeek maintenant)
# OLLAMA_MODEL=llama3:latest

# Timeout pour les requêtes LLM (en secondes)
# OLLAMA_TIMEOUT=180

# Nombre max de tentatives
# OLLAMA_MAX_RETRIES=3

# ==============================================================================
# LLM Configuration (Gemini - Alternative - Commentée)
# ==============================================================================

# API Key Google Gemini (obtenir sur aistudio.google.com/app/apikey)
# GEMINI_API_KEY=your_gemini_api_key_here

# Modèle Gemini utilisé (models/gemini-1.5-pro, models/gemini-1.5-flash, etc.)
# GEMINI_MODEL=gemini-1.5-pro

# ==============================================================================
# Optional: Anthropic Claude (alternative à Ollama)
# ==============================================================================

# ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ==============================================================================
# Logging & Monitoring
# ==============================================================================

# Niveau de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Activer les métriques Prometheus
ENABLE_METRICS=false

# Port pour les métriques
METRICS_PORT=9090

# ==============================================================================
# Development Settings
# ==============================================================================

# Désactiver auth en développement (true/false)
DISABLE_AUTH_IN_DEV=false
