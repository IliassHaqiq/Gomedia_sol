# NVIDIA NIM Configuration
# Get your API key from: https://build.nvidia.com/meta/llama-3_70b
NIM_API_KEY=nvapi-your-api-key-here

# Model to use (default: meta/llama-3-70b-instruct)
# Available models: https://build.nvidia.com/explore/reasoning
NIM_MODEL=meta/llama-3-70b-instruct

# API endpoint
# Change this to http://localhost:8000/v1 if running local NIM
NIM_API_URL=https://integrate.api.nvidia.com/v1

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/gomedia

# File upload configuration
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=INFO

# Optional: For UltraMatrix product detection
ULTRAMATRIX_HOOK_URL=https://hooks.ultramatrix.com/webhook-endpoint
