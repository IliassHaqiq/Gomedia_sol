# Ollama Configuration
# Install: https://ollama.com/download
# Start: ollama serve
# Pull model: ollama pull llama3.2:latest

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TIMEOUT=180
OLLAMA_MAX_RETRIES=3
OLLAMA_REQUEST_INTERVAL=0

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/gomedia

# File upload configuration
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=INFO

# Optional: For UltraMatrix product detection
ULTRAMATRIX_HOOK_URL=https://hooks.ultramatrix.com/webhook-endpoint
